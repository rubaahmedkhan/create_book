{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Better Auth TypeScript service for user authentication",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "migrate": "better-auth migrate"
  },
  "keywords": [
    "authentication",
    "better-auth",
    "typescript",
    "neon-postgres"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@neondatabase/serverless": "^0.9.0",
    "better-auth": "^1.0.0",
    "dotenv": "^16.0.0",
    "hono": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
